{
  "name": "obsidian-dedao-brain-sync",
  "version": "1.4.0",
  "description": "Dedao Brain Sync for Obsidian",
  "main": "main.js",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --dev",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:e2e:openapi": "vitest run tests/openapi-knowledge-sync.e2e.spec.ts",
    "smoke:getnote": "node scripts/smoke-getnote-api.mjs"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "getnote"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "happy-dom": "^20.10.6",
    "obsidian": "^1.13.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "preact": "^10.29.3",
    "react": "npm:@preact/compat",
    "react-dom": "npm:@preact/compat"
  }
}
